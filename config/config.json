{
    "name": "halftoning_dev",
    "model": "HalftoningPolicyNet",
	"data_dir": "dataset/",
    "train_data_dir": "dataset/HalftoneVOC2012/train",
    "val_data_dir": "dataset/HalftoneVOC2012/val",
    "test_data_dir": "dataset/HalftoneVOC2012/test",
	"save_dir": "./",
    "initial_ckpt": "halftoning_dev/model_last.pth.tar",
    "trainer": {
        "epochs": 1000,
        "save_epochs": 1,
        "val_epochs": 1,
        "enable_compile": true,
        "use_amp": true,
        "compile_mode": "max-autotune"
    },
    "data_loader": {
        "batch_size": 64,
        "shuffle": true,
        "num_workers": 8,
        "prefetch_factor": 8,
        "crop_size": 64
    },
    "cuda": true,
    "optimizer_type": "Adam",
    "optimizer": {
        "lr": 3e-4,
        "weight_decay": 0
    },
    "lr_scheduler_type": "CosineAnnealingLR",
    "lr_scheduler": {
        "T_max": 200000,
        "eta_min": 1e-5,
        "last_epoch": -1
    },
    "seed": 131
}